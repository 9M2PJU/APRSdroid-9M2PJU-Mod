<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon foreground — the app logo centered within the 108dp
     canvas. The system applies a launcher mask (circle, squircle, etc.)
     and only the center 66% ("safe zone") is guaranteed to be visible.
     The inset keeps the logo within the safe zone so it doesn't get
     cropped by the mask. -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/icon"
    android:insetTop="18%"
    android:insetBottom="18%"
    android:insetLeft="18%"
    android:insetRight="18%" />
