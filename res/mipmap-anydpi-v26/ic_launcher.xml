<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon for Android 8.0+ (API 26+).
     On Android 13+ the launcher applies a mask (circle, squircle, etc.)
     and shows the background filling the entire masked area with the
     foreground on top. Without this, the system shrinks the plain PNG
     icon and adds a default background around it. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
